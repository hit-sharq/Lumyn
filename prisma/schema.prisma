generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model News {
  id          String   @id @default(cuid())
  title       String
  excerpt     String
  content     String
  category    String
  image       String
  author      String
  publishedAt DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([category])
  @@index([publishedAt])
}


model Blog {
  id          String   @id @default(cuid())
  title       String
  excerpt     String
  content     String
  category    String
  image       String
  author      String
  tags        String[]
  isPublished Boolean  @default(true)
  featured    Boolean  @default(false)
  publishedAt DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([category])
  @@index([publishedAt])
  @@index([isPublished])
  @@index([featured])
}

model Event {
  id          String   @id @default(cuid())
  title       String
  description String
  date        DateTime
  time        String
  location    String
  image       String
  category    String
  registrationLink String?
  isStaple    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([date])
  @@index([category])
}

model GalleryImage {
  id          String   @id @default(cuid())
  title       String
  description String?
  imageUrl    String
  category    String
  uploadedAt  DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category])
  @@index([uploadedAt])
}

model Member {
  id        String   @id @default(cuid())
  firstName String
  lastName  String
  email     String   @unique
  phone     String?
  year      String
  major     String
  interests String?
  joinedAt  DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
  @@index([joinedAt])
}

model Contact {
  id        String   @id @default(cuid())
  name      String
  email     String
  subject   String
  message   String
  createdAt DateTime @default(now())
  read      Boolean  @default(false)

  @@index([createdAt])
  @@index([read])
}

model Newsletter {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())

  @@index([email])
  @@index([createdAt])
}

model LeadershipTeam {
  id          String   @id @default(cuid())
  name        String
  position    String
  role        String
  imageUrl    String?
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([order])
}

model Project {
  id          String   @id @default(cuid())
  title       String
  description String
  image       String
  category    String
  technologies String[]
  liveUrl     String?
  githubUrl   String?
  featured    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([category])
  @@index([featured])
}

model Career {
  id                 String   @id @default(cuid())
  title              String
  company            String
  description        String
  requirements       String?
  location           String?
  type               String   @default("full-time")
  salary             String?
  applicationDeadline DateTime?
  applicationUrl     String?
  contactEmail       String?
  featured           Boolean  @default(false)
  image              String?
  jobType            String   @default("formal") // formal (application form) or informal (whatsapp/call)
  whatsappNumber     String?  // WhatsApp contact for informal jobs
  phoneNumber        String?  // Phone contact for informal jobs
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([type])
  @@index([featured])
  @@index([applicationDeadline])
  @@index([jobType])
}


model Partner {
  id          String   @id @default(cuid())
  name        String
  description String?
  logoUrl     String?
  website     String?
  category    String   @default("general")
  featured    Boolean  @default(false)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([category])
  @@index([featured])
  @@index([order])
}

model JobApplication {
  id                String   @id @default(cuid())
  jobId             String
  jobTitle          String
  jobCompany        String
  firstName         String
  lastName          String
  email             String
  phone             String
  linkedIn          String?
  portfolio         String?
  coverLetter       String
  experience        String
  availability      String
  salaryExpectation String?
  additionalInfo    String?
  resumeUrl         String?
  status            String   @default("pending")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([jobId])
  @@index([status])
  @@index([createdAt])
  @@index([email])
}

// ─── Lumyn Studio ────────────────────────────────────────────────────────────

model StudioTemplate {
  id            String   @id @default(cuid())
  title         String
  description   String
  category      String
  previewImage  String
  previewImages String[]
  tags          String[]
  isFree        Boolean  @default(false)
  price         Float    @default(0)
  downloadUrl   String?
  featured      Boolean  @default(false)
  isPublished   Boolean  @default(true)
  downloadCount Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  purchases     StudioPurchase[]
  reviews       StudioReview[]

  @@index([category])
  @@index([isFree])
  @@index([featured])
  @@index([isPublished])
}

model StudioPurchase {
  id         String         @id @default(cuid())
  userId     String
  userEmail  String
  templateId String
  template   StudioTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  amount     Float          @default(0)
  createdAt  DateTime       @default(now())

  @@unique([userId, templateId])
  @@index([userId])
  @@index([templateId])
  @@index([createdAt])
}

model StudioReview {
  id         String         @id @default(cuid())
  userId     String
  userEmail  String
  userName   String
  templateId String
  template   StudioTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  rating     Int
  comment    String?
  createdAt  DateTime       @default(now())

  @@unique([userId, templateId])
  @@index([templateId])
  @@index([userId])
}

// ─── Lumyn Launch ────────────────────────────────────────────────────────────

model LaunchPortfolio {
  id          String   @id @default(cuid())
  userId      String
  userEmail   String
  username    String   @unique
  displayName String
  templateId  String
  isPublished Boolean  @default(false)
  about       String?
  title       String?
  avatarUrl   String?
  skills      String[]
  socialLinks Json?
  projects    LaunchProject[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@index([username])
  @@index([isPublished])
}

model LaunchProject {
  id          String          @id @default(cuid())
  portfolioId String
  portfolio   LaunchPortfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  title       String
  description String
  imageUrl    String?
  liveUrl     String?
  githubUrl   String?
  tags        String[]
  order       Int             @default(0)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([portfolioId])
}

// ─── Lumyn Market ────────────────────────────────────────────────────────────

model MarketCreatorProfile {
  id          String          @id @default(cuid())
  userId      String          @unique
  userEmail   String
  displayName String
  bio         String?
  avatarUrl   String?
  website     String?
  twitter     String?
  isVerified  Boolean         @default(false)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  products    MarketProduct[]

  @@index([userId])
}

model MarketProduct {
  id          String               @id @default(cuid())
  creatorId   String
  creator     MarketCreatorProfile @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  title       String
  description String
  category    String
  price       Float
  fileUrl     String?
  previewImage String?
  tags        String[]
  isFeatured  Boolean              @default(false)
  isPublished Boolean              @default(true)
  salesCount  Int                  @default(0)
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  purchases   MarketPurchase[]

  @@index([creatorId])
  @@index([category])
  @@index([isFeatured])
  @@index([isPublished])
}

model MarketPurchase {
  id        String        @id @default(cuid())
  userId    String
  userEmail String
  productId String
  product   MarketProduct @relation(fields: [productId], references: [id], onDelete: Cascade)
  amount    Float
  createdAt DateTime      @default(now())

  @@unique([userId, productId])
  @@index([userId])
  @@index([productId])
  @@index([createdAt])
}


// ─── Payments ────────────────────────────────────────────────────────────────

model PaymentOrder {
  id                String   @id @default(cuid())
  merchantReference String   @unique
  orderTrackingId   String
  userId            String
  userEmail         String
  type              String
  itemId            String
  amount            Float
  currency          String   @default("KES")
  status            String   @default("PENDING")
  paymentMethod     String?
  confirmationCode  String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([userId])
  @@index([orderTrackingId])
  @@index([status])
}

// ─── Lumyn Hire (Paid Job Board) ─────────────────────────────────────────────

model PaidJobPost {
  id               String   @id @default(cuid())
  userId           String
  userEmail        String
  companyName      String
  companyLogo      String?
  companyWebsite   String?
  jobTitle         String
  jobDescription   String
  location         String   @default("Remote")
  jobType          String   @default("Full-time")
  salary           String?
  applicationUrl   String?
  applicationEmail String?
  category         String   @default("Technology")
  tags             String[]
  plan             String   @default("basic")
  amount           Float
  isPaid           Boolean  @default(false)
  isPublished      Boolean  @default(false)
  isFeatured       Boolean  @default(false)
  expiresAt        DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([userId])
  @@index([isPublished])
  @@index([isFeatured])
  @@index([category])
}
